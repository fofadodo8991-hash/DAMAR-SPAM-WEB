{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/spam", "dest": "/spam.html" },
    { "handle": "filesystem" }
  ]
}
